/*
 * Catppuccin Mocha theme for Mumble.
 * Uses the Default theme's icons as a fallback via the theme search path.
 */

ApplicationPalette {
  qproperty-window: #1f232a;
  qproperty-windowtext: #d8e1ee;
  qproperty-windowtext_disabled: #738091;
  qproperty-base: #171b22;
  qproperty-alternatebase: #2c3440;
  qproperty-text: #d8e1ee;
  qproperty-text_disabled: #738091;
  qproperty-tooltipbase: #0f1319;
  qproperty-tooltiptext: #d8e1ee;
  qproperty-tooltiptext_disabled: #738091;
  qproperty-brighttext: #0f1319;
  qproperty-brighttext_disabled: #738091;
  qproperty-highlight: #74a8d6;
  qproperty-highlightedtext: #0f1319;
  qproperty-highlightedtext_disabled: #738091;
  qproperty-button: #2c3440;
  qproperty-buttontext: #d8e1ee;
  qproperty-buttontext_disabled: #738091;
  qproperty-link: #79b7d3;
  qproperty-linkvisited: #9eb1d4;
  qproperty-light: #3d4754;
  qproperty-midlight: transparent;
  qproperty-mid: #3d4754;
  qproperty-dark: transparent;
  qproperty-shadow: #2c3440;
}

QObject,
QObject::separator,
QObject::handle,
QObject::tab-bar,
QObject::tab,
QObject::section {
  font-family: "Segoe UI", Frutiger, "Frutiger Linotype", "Dejavu Sans", "Helvetica Neue", "Microsoft YaHei UI", "PingFang SC", "Noto Sans SC", Arial, sans-serif;
  font-size: 10pt;
  margin: 0;
  padding: 0;
  outline: 0;
  border: 0;
  selection-background-color: #74a8d6;
  selection-color: #0f1319;
  alternate-background-color: transparent;
  color: #d8e1ee;
  border-radius: 4px;
}

QMainWindow,
QDockWidget {
  background-color: #1f232a;
}

QDialog,
QWizard *,
QCalendarWidget *,
#qswPages > QObject {
  background-color: #171b22;
  color: #d8e1ee;
}

QObject:disabled,
QObject::item:disabled {
  color: #738091;
}

a {
  color: #79b7d3;
  text-decoration: none;
}

QObject::separator {
  height: 4px;
  width: 4px;
}

QObject::separator:hover {
  background: #2c3440;
}

DockTitleBar {
  font-size: 8pt;
}

QToolTip,
QWhatsThis {
  font-size: 8pt;
  min-height: 1.3em;
  border: 1px solid #536071;
  border-radius: 6px;
  background-color: #0f1319;
  color: #d8e1ee;
}

QTextBrowser,
QTextEdit,
QPlainTextEdit {
  background-color: #171b22;
  color: #d8e1ee;
  border: 1px solid #3d4754;
}

QToolBar {
  background-color: #1f232a;
  spacing: 1px;
  padding: 1px 1px;
}

QToolButton {
  border: 1px solid transparent;
  border-radius: 8px;
  padding: 1px 2px;
  margin: 0;
}

QToolButton:on {
  background-color: #3d4754;
  border: 1px solid #3d4754;
}

QToolButton:hover {
  background-color: #3d4754;
  border: 1px solid #3d4754;
}

QToolButton:pressed {
  background-color: #74a8d6;
  border: 1px solid #74a8d6;
  color: #0f1319;
}

QToolBar::separator {
  background: #738091;
  height: 1px;
  margin: 3px;
  width: 1px;
}

QToolBar::separator:hover {
  background: #738091;
  border: 0;
}

QToolButton#qt_toolbar_ext_button {
  min-width: 8px;
  width: 8px;
  padding: 1px;
  qproperty-icon: url(skin:controls/toolbar_ext.svg);
}

QToolBar::handle:horizontal {
  image: url(skin:controls/handle_horizontal.svg);
  width: 8px;
  padding: 4px;
}

QToolBar::handle:vertical {
  image: url(skin:controls/handle_vertical.svg);
  height: 8px;
  padding: 4px;
}

QMenuBar::item {
  background-color: transparent;
  border-radius: 8px;
  margin: 0 1px;
  padding: 2px 8px;
}

QMenuBar::item:selected {
  background: #74a8d6;
  color: #0f1319;
}

QMenuBar::item:pressed {
  background: #6798c1;
  color: #0f1319;
}

QMenu {
  background: #171b22;
  border: 1px solid #3d4754;
  color: #d8e1ee;
}

QMenu::item {
  border: 1px solid transparent;
  color: #d8e1ee;
  padding: 5px 16px 5px 8px;
  border-radius: 6px;
}

QMenu QLabel {
  margin: 0;
  padding: 5px 8px 5px 25px;
}

QMenu QSlider {
  padding-top: 5px;
  padding-bottom: 5px;
}

QMenu::icon {
  left: 4px;
}

QMenu::item:selected {
  background: #3d4754;
  border: 1px solid #3d4754;
}

QMenu::item:disabled {
  border: 1px solid transparent;
  background: transparent;
}

QMenu::separator {
  background: #738091;
  height: 1px;
}

QPushButton {
  background-color: #2c3440;
  border: 1px solid #3d4754;
  color: #d8e1ee;
  font-size: 11pt;
  padding: 4px 20px;
}

QPushButton:focus {
  border-color: #74a8d6;
}

QPushButton:hover {
  background-color: #3d4754;
  border-color: #536071;
}

QPushButton:pressed,
QPushButton:pressed:focus {
  background-color: #74a8d6;
  border-color: #74a8d6;
  color: #0f1319;
}

QGroupBox,
#qwMacWarning,
#qwInlineNotice {
  background-color: #2c3440;
  border: 1px solid #3d4754;
  color: #d8e1ee;
  font-size: 12pt;
  padding: 4px;
  padding-top: 1em;
}

QGroupBox::title {
  background-color: transparent;
  margin: 6px 8px;
}

QListView,
QListWidget {
  background-color: #171b22;
  border: 1px solid #3d4754;
}

QListView::item,
QListWidget::item {
  border-radius: 6px;
  border: 1px solid transparent;
  color: #d8e1ee;
  padding: 2px 6px;
}

QListView::item:hover,
QListWidget::item:hover {
  background-color: #2c3440;
  border: 1px solid #2c3440;
}

QListView::item:selected,
QListWidget::item:selected {
  background-color: #3d4754;
  border: 1px solid #3d4754;
  color: #d8e1ee;
}

QListView::item:selected:active,
QListWidget::item:selected:active {
  background-color: #74a8d6;
  border: 1px solid #74a8d6;
  color: #0f1319;
}

QTreeView {
  background-color: #171b22;
  color: #d8e1ee;
  selection-background-color: #171b22;
  selection-color: #d8e1ee;
  border: 1px solid #3d4754;
}

QTreeView::item {
  min-width: 60px;
  border: 1px solid transparent;
  border-left: 0;
  border-right: 0;
  color: #d8e1ee;
  padding: 2px 6px;
  border-radius: 0;
}

QTreeView::item:first,
QTreeView::item:only-one {
  border-left: 1px solid transparent;
  border-top-left-radius: 6px;
  border-bottom-left-radius: 6px;
}

QTreeView::item:last,
QTreeView::item:only-one {
  border-right: 1px solid transparent;
  border-top-right-radius: 6px;
  border-bottom-right-radius: 6px;
}

QTreeView::item:hover,
QTreeView::item:focus {
  background-color: #2c3440;
  border-color: #2c3440;
}

QTreeView::item:selected {
  background-color: #3d4754;
  border: 1px solid #3d4754;
  border-right: 0;
  border-left: 0;
  color: #d8e1ee;
}

QTreeView::item:selected:first,
QTreeView::item:selected:only-one {
  border-left: 1px solid #3d4754;
}

QTreeView::item:selected:last,
QTreeView::item:selected:only-one {
  border-right: 1px solid #3d4754;
}

QTreeView::item:selected:active {
  background-color: #74a8d6;
  border: 1px solid #74a8d6;
  border-right: 0;
  border-left: 0;
  color: #0f1319;
}

QTreeView::item:selected:active:first,
QTreeView::item:selected:active:only-one {
  border-left: 1px solid #74a8d6;
}

QTreeView::item:selected:active:last,
QTreeView::item:selected:active:only-one {
  border-right: 1px solid #74a8d6;
}

QTreeView::branch {
  background-color: #171b22;
  border-image: none;
  image: none;
  padding-left: 3px;
  padding-top: 1px;
}

QTreeView::branch:has-children:closed {
  image: url(skin:controls/branch_closed.svg);
}

QTreeView::branch:has-children:open {
  image: url(skin:controls/branch_open.svg);
}

QHeaderView {
  border-bottom: 1px solid #3d4754;
  border-radius: 0;
}

QHeaderView::section {
  border: 0;
  background-color: #2c3440;
  color: #d8e1ee;
  padding: 4px 20px 4px 8px;
  border-radius: 0;
}

QHeaderView::down-arrow {
  image: url(skin:controls/arrow_down.svg);
}

QHeaderView::up-arrow {
  image: url(skin:controls/arrow_up.svg);
}

QTabWidget::pane {
  background-color: #2c3440;
  border: 1px solid #3d4754;
}

QTabWidget::pane:top {
  margin-top: -1px;
  border-radius: 6px;
  border-top-left-radius: 0;
}

QTabWidget::pane:bottom {
  margin-bottom: -1px;
  border-radius: 6px;
  border-bottom-left-radius: 0;
}

QTabWidget::tab-bar {
  background-color: #171b22;
}

QTabBar::tab {
  color: #bac2de;
  background-color: #0f1319;
  padding: 6px 16px;
  border-radius: 0;
  border: 1px solid #3d4754;
  border-right: 0;
}

QTabBar::tab:last,
QTabBar::tab:only-one {
  border-right: 1px solid #3d4754;
}

QTabBar::tab:hover {
  background-color: #3d4754;
}

QTabBar::tab:disabled {
  color: #738091;
}

QTabBar::tab:selected {
  color: #d8e1ee;
  background-color: #2c3440;
}

QTabBar::tab:top {
  border-bottom: 0;
  margin-bottom: 1px;
}

QTabBar::tab:bottom {
  border-top: 0;
  margin-top: 1px;
}

QTabBar::tab:top:selected {
  padding-bottom: 7px;
  margin-bottom: 0;
}

QTabBar::tab:bottom:selected {
  padding-top: 7px;
  margin-top: 0;
}

QScrollBar {
  border-radius: 0;
  font-size: 10pt;
}

QScrollBar:vertical {
  border-left: 1px solid #3d4754;
  width: 1em;
}

QScrollBar:horizontal {
  border-top: 1px solid #3d4754;
  height: 1em;
}

QScrollBar::handle {
  margin: -1px;
  background: #738091;
  border: 1px solid #3d4754;
}

QScrollBar::handle:vertical {
  min-height: 10px;
}

QScrollBar::handle:horizontal {
  min-width: 10px;
}

QScrollBar::handle:hover {
  background: #9399b2;
}

QScrollBar::left-arrow,
QScrollBar::right-arrow,
QScrollBar::up-arrow,
QScrollBar::down-arrow,
QScrollBar::sub-line,
QScrollBar::add-line,
QScrollBar::add-page,
QScrollBar::sub-page {
  background: #1f232a;
  height: 0;
  width: 0;
  border-radius: 0;
  border: 0;
}

QAbstractScrollArea::corner {
  border-left: 1px solid #3d4754;
  border-top: 1px solid #3d4754;
  height: 0;
  width: 0;
  background: #171b22;
}

QLineEdit,
QComboBox,
QSpinBox,
QAbstractSpinBox {
  color: #d8e1ee;
  padding: 4px;
  min-height: 1em;
}

QComboBox,
QSpinBox,
QAbstractSpinBox {
  border: 1px solid #3d4754;
  background-color: #2c3440;
}

QLineEdit,
QTextEdit,
QPlainTextEdit,
QSpinBox,
QAbstractSpinBox,
QComboBox:editable {
  border: 1px solid #3d4754;
  background-color: #171b22;
}

QPushButton:disabled,
QLineEdit:disabled,
QTextEdit:disabled,
QPlainTextEdit:disabled,
QListWidget:disabled,
QTreeWidget:disabled,
QComboBox:disabled,
QSpinBox:disabled,
QAbstractSpinBox:disabled {
  border: 1px solid transparent;
  background-color: #0f1319;
}

QComboBox::drop-down,
QAbstractSpinBox::drop-down,
QSpinBox::drop-down,
QDateTimeEdit::drop-down {
  background-color: #171b22;
  border: 0;
  margin-left: 4px;
  margin-right: 12px;
  margin-top: 5px;
}

QComboBox::down-arrow,
QDateTimeEdit::down-arrow {
  margin-top: -2px;
  image: url(skin:controls/arrow_down.svg);
  width: 14px;
}

QComboBox::down-arrow:disabled,
QDateTimeEdit::down-arrow:disabled {
  image: url(skin:controls/arrow_down_disabled.svg);
}

QToolButton::menu-arrow,
QToolButton::menu-indicator,
QPushButton::menu-arrow,
QPushButton::menu-indicator {
  image: url(skin:controls/arrow_down.svg);
  subcontrol-origin: padding;
  subcontrol-position: center right;
  top: 2px;
  right: 2px;
  width: 14px;
}

QSpinBox::down-button,
QAbstractSpinBox::down-button {
  padding-right: 4px;
  image: url(skin:controls/arrow_down.svg);
  width: 14px;
  padding-bottom: 1px;
}

QSpinBox::down-button:disabled,
QAbstractSpinBox::down-button:disabled {
  image: url(skin:controls/arrow_down_disabled.svg);
}

QSpinBox::up-button,
QAbstractSpinBox::up-button {
  padding-right: 4px;
  image: url(skin:controls/arrow_up.svg);
  width: 14px;
  padding-top: 1px;
}

QSpinBox::up-button:disabled,
QAbstractSpinBox::up-button:disabled {
  image: url(skin:controls/arrow_up_disabled.svg);
}

QComboBox QAbstractItemView {
  background-color: #171b22;
  border: 1px solid #3d4754;
  color: #d8e1ee;
  border-radius: 0;
}

QLabel,
QCheckBox,
QAbstractCheckBox,
QTreeView::indicator,
QRadioButton {
  color: #d8e1ee;
  background: transparent;
}

QCheckBox::indicator,
QTreeView::indicator {
  background-color: #2c3440;
  border: 1px solid #3d4754;
  height: 13px;
  width: 13px;
  margin-top: 1px;
}

QMenu::indicator {
  padding-top: 2px;
  width: 12px;
  height: 12px;
  left: 6px;
  margin-right: 8px;
}

QCheckBox::indicator:checked,
QMenu::indicator:checked,
QTreeView::indicator:checked {
  image: url(skin:controls/checkbox_check_dark.svg);
}

QCheckBox::indicator:disabled,
QTreeView::indicator:disabled {
  border: 1px solid #2c3440;
  background-color: #0f1319;
}

QCheckBox::indicator:checked:disabled,
QTreeView::indicator:checked:disabled {
  border: 1px solid transparent;
  image: url(skin:controls/checkbox_check_disabled.svg);
}

QRadioButton::indicator {
  background: #2c3440;
  border: 1px solid #3d4754;
  border-radius: 7px;
  height: 12px;
  width: 12px;
}

QRadioButton::indicator:checked {
  image: url(skin:controls/radio_check_dark.svg);
}

QRadioButton::indicator:checked:disabled {
  image: url(skin:controls/radio_check_disabled.svg);
}

QCheckBox::indicator:hover,
QTreeView::indicator:hover,
QRadioButton::indicator:hover,
QComboBox:hover,
QLineEdit:hover,
QSpinBox:hover,
QAbstractSpinBox:hover,
QComboBox:editable:hover {
  border-color: #536071;
}

QCheckBox::indicator:focus,
QTreeView::indicator:focus,
QRadioButton::indicator:focus,
QComboBox:focus,
QLineEdit:focus,
QTextEdit:focus,
QPlainTextEdit:focus,
QSpinBox:focus,
QAbstractSpinBox:focus,
QComboBox:editable:focus {
  border-color: #74a8d6;
}

QSlider::groove {
  background: #2c3440;
  border: 1px solid #2c3440;
  border-radius: 4px;
  font-size: 3pt;
}

QSlider::groove:horizontal {
  height: 0.8em;
}

QSlider::groove:vertical {
  width: 0.8em;
}

QSlider::groove:disabled,
QSlider::sub-page:disabled {
  background: #0f1319;
  border: 1px solid transparent;
  border-radius: 4px;
}

QSlider::sub-page {
  background: #74a8d6;
  border: 1px solid #74a8d6;
  border-radius: 4px;
}

QSlider::handle {
  background: #9399b2;
  border: 1px solid #2c3440;
  border-radius: 4px;
  font-size: 4pt;
}

QSlider::handle:horizontal {
  margin: -5px -1px;
  width: 4.5em;
}

QSlider::handle:vertical {
  margin: -1px -5px;
  height: 4.5em;
}

QSlider::handle:focus {
  background-color: #9eb1d4;
  border-color: #74a8d6;
}

QSlider::handle:hover {
  background-color: #bac2de;
}

QSlider::handle:pressed {
  background-color: #d8e1ee;
}

QFontDialog {
  min-width: 32em;
  min-height: 24em;
}

QColorDialog QColorLuminancePicker {
  background-color: transparent;
}

QMessageBox,
QDialogButtonBox {
  dialogbuttonbox-buttons-have-icons: 0;
}

LogTextBrowser,
#qdsChat {
  margin: 0 2px;
  min-height: 120px;
  min-width: 40px;
  border-color: #3d4754;
}

UserView {
  margin: 0 2px;
  min-height: 120px;
  min-width: 40px;
}

UserView::item {
  padding: 0;
  padding-top: -1px;
}

#qdwChat {
  background-color: #1f232a;
  border: 1px solid #3d4754;
}

#qcbPersistentChatScope,
#qtePersistentChatWelcome,
#qtePersistentChatHistory,
#qteChat,
#qleAdvertisedRelease,
#qleAdvertisedOS,
#qleAdvertisedOSVersion {
  background-color: #171b22;
  color: #d8e1ee;
  border: 1px solid #3d4754;
  selection-background-color: #74a8d6;
  selection-color: #0f1319;
}

#qcbPersistentChatScope {
  padding: 4px;
}

#qtePersistentChatWelcome,
#qtePersistentChatHistory,
#qteChat,
#qdwChat > QTextEdit {
  padding: 0;
  margin: 0 1px 1px 1px;
  font-size: 10pt;
}

#qfPersistentChatDivider {
  background-color: #738091;
  color: #738091;
  border: 0;
  min-height: 1px;
  max-height: 1px;
}

#qcbLinkPreviews {
  color: #d8e1ee;
}

.persistent-chat-preview-card {
  background-color: #171b22;
  border: 1px solid #3d4754;
}

.persistent-chat-preview-subtitle,
.persistent-chat-preview-status {
  color: #a6adc8;
}

.persistent-chat-preview-status {
  font-style: italic;
}

.log-time {
  background-color: transparent;
  color: #a6adc8;
  font-size: 9pt;
}

.log-server {
  background-color: transparent;
  color: #f38ba8;
  font-weight: bold;
}

.log-channel {
  background-color: transparent;
  color: #fab387;
  font-weight: bold;
}

.log-privilege {
  background-color: transparent;
  color: #eba0ac;
  font-weight: bold;
}

.log-target,
.log-source {
  background-color: transparent;
  color: #a6e3a1;
  font-weight: bold;
}

QListView#qlwIcons {
  padding: 0;
  background-color: transparent;
  border: 0;
  font-size: 12pt;
  min-width: 165%;
  margin-left: 4px;
  margin-top: 12px;
}

QListView#qlwIcons::item {
  margin-bottom: 1px;
  padding: 5px 7px;
}

QListView#qlwIcons::item:hover {
  border-color: #2c3440;
  background-color: #2c3440;
}

QListView#qlwIcons::item:selected {
  background-color: #3d4754;
  border: 1px solid #3d4754;
}

QListView#qlwIcons::item:focus {
  background-color: #74a8d6;
  border: 1px solid #74a8d6;
  color: #0f1319;
}

AboutDialog > QTextBrowser,
AboutDialog QTextEdit {
  border: 0;
}

#qtbToolBar {
  border: 1px solid transparent;
  background: transparent;
}

TalkingUI {
  background-color: #171b22;
}

TalkingUI > * {
  background-color: #171b22;
}

TalkingUI [selected="false"] {
  background-color: #171b22;
}

TalkingUI [selected="false"]:hover {
  background-color: #2c3440;
}

TalkingUI [selected="true"] {
  background-color: #74a8d6;
  border: 1px solid #74a8d6;
}

TalkingUI > QFrame {
  border: 1px solid #3d4754;
  border-radius: 6px;
}
