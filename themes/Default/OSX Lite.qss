/*
 * Mumble Lite Theme for OSX
 * https://github.com/mumble-voip/mumble-theme
 *
 * Based on MetroMumble Theme by xPoke
 * https://github.com/xPoke
 *
 * Originally forked from Flat Mumble Theme by xPaw (xpaw.ru)
 *
 * Licensed under The Do What The Fuck You Want To Public License (WTFPL)
 */
/*
 * YOU SHOULD NOT MODIFY THIS FILE
 * Edit the files in the "source" folder instead.
 * See project README
 *
 */
ApplicationPalette {
  qproperty-window: #edf1f5;
  qproperty-windowtext: #25313d;
  qproperty-windowtext_disabled: #95a1ad;
  qproperty-base: #FFF;
  qproperty-alternatebase: #f8fafc;
  qproperty-text: #16212c;
  qproperty-text_disabled: #95a1ad;
  qproperty-tooltipbase: #FFF;
  qproperty-tooltiptext: #16212c;
  qproperty-tooltiptext_disabled: #95a1ad;
  qproperty-brighttext: #FFF;
  qproperty-brighttext_disabled: #95a1ad;
  qproperty-highlight: #4d8fbe;
  qproperty-highlightedtext: #FFF;
  qproperty-highlightedtext_disabled: #95a1ad;
  qproperty-button: #FFF;
  qproperty-buttontext: #16212c;
  qproperty-buttontext_disabled: #95a1ad;
  qproperty-link: #257ea8;
  qproperty-linkvisited: #257ea8;
  qproperty-light: #cfd7e0;
  qproperty-midlight: transparent;
  qproperty-mid: #cfd7e0;
  qproperty-dark: transparent;
  qproperty-shadow: #cfd7e0;
}

QObject,
QObject::separator,
QObject::handle,
QObject::tab-bar,
QObject::tab,
QObject::section {
  font-family: -apple-system, ".SF NS Text", "Helvetica Neue", "Lucida Grande";
  font-size: 13pt;
  margin: 0;
  padding: 0;
  outline: 0;
  border: 0;
  selection-background-color: #4d8fbe;
  selection-color: #FFF;
  alternate-background-color: transparent;
  color: #25313d;
  border-radius: 2px;
}

QMainWindow,
QDockWidget {
  background-color: #edf1f5;
}

QDialog,
QWizard *,
QCalendarWidget *,
#qswPages > QObject {
  background-color: #edf1f5;
  color: #16212c;
}

QObject:disabled,
QObject::item:disabled {
  color: #95a1ad;
}

a {
  color: #257ea8;
  text-decoration: none;
}

QObject::separator {
  height: 4px;
  width: 4px;
}

QObject::separator:hover {
  background: #dbe4ec;
}

DockTitleBar {
  font-size: 10pt;
}

QToolTip,
QWhatsThis {
  font-size: 11pt;
  min-height: 1.3em;
  border: 1px solid #5f6d7b;
  border-radius: 0;
  background-color: #FFF;
  color: #16212c;
}

QTextBrowser,
QTextEdit {
  background-color: #FFF;
  color: #16212c;
  border: 1px solid #cfd7e0;
}

QToolBar {
  background-color: #edf1f5;
  spacing: 1px;
  padding: 1px 1px;
}

QToolButton {
  border: 1px solid transparent;
  border-radius: 6px;
  padding: 1px 2px;
  margin: 0;
}

QToolButton:on {
  background-color: #FFF;
  border: 1px solid #c4d0dc;
}

QToolButton:hover {
  background-color: #eef4f8;
  border: 1px solid #cfd9e3;
}

QToolButton:pressed {
  background-color: #cfd9e3;
}

QToolBar::separator {
  background: #d4dde7;
  height: 1px;
  margin: 3px;
  width: 1px;
}

QToolBar::separator:hover {
  background: #d4dde7;
  border: 0;
}

QToolButton#qt_toolbar_ext_button {
  min-width: 8px;
  width: 8px;
  padding: 1px;
  qproperty-icon: url(skin:controls/toolbar_ext.svg);
}

QToolBar::handle:horizontal {
  image: url(skin:controls/handle_horizontal.svg);
  width: 8px;
  padding: 4px;
}

QToolBar::handle:vertical {
  image: url(skin:controls/handle_vertical.svg);
  height: 8px;
  padding: 4px;
}

QMenuBar::item {
  background-color: transparent;
  border-radius: 6px;
  margin: 0 1px;
  padding: 2px 8px;
}

QMenuBar::item:selected {
  background: #4d8fbe;
  color: #FFF;
}

QMenuBar::item:pressed {
  background: #3f7ca9;
  color: #FFF;
}

QMenu {
  background: #f7fafc;
  border: 1px solid #cfd7e0;
  color: #16212c;
}

QMenu::item {
  border: 1px solid transparent;
  color: #16212c;
  padding: 5px;
  padding-right: 16px;
  padding-left: 8px;
  border-radius: 2px;
}

QMenu QLabel {
  margin: 0px;
  padding: 5px;
  padding-right: 8px;
  padding-left: 25px;
}

QMenu QSlider {
  padding-top: 5px;
  padding-bottom: 5px;
}

QMenu::icon {
  left: 4px;
}

QMenu::item:selected {
  background: #ddebf5;
  border: 1px solid #aac4d9;
}

QMenu::item:disabled {
  border: 1px solid transparent;
  background: transparent;
}

QMenu::separator {
  background: #d4dde7;
  height: 1px;
}

QPushButton {
  background-color: #FFF;
  border: 1px solid #c7d2dd;
  color: #16212c;
  font-size: 15pt;
  padding: 3px 20px;
}

QPushButton:focus {
  background-color: #eef6fb;
}

QPushButton:hover {
  background-color: #f5f8fb;
  border-color: #b0beca;
}

QPushButton:hover:focus {
  background-color: #dcecf6;
  border-color: #79abc9;
}

QPushButton:focus {
  border-color: #6ea8d3;
}

QPushButton:pressed,
QPushButton:pressed:focus {
  background-color: #4d8fbe;
  border-color: #4d8fbe;
  color: #FFF;
}

QGroupBox,
#qwMacWarning,
#qwInlineNotice {
  background-color: #f8fafc;
  border: 1px solid #cfd7e0;
  color: #16212c;
  font-size: 16pt;
  padding: 4px;
  padding-top: 1em;
}

QGroupBox::title {
  background-color: transparent;
  margin: 6px;
  margin-left: 8px;
  margin-right: 8px;
}

QListView {
  background-color: #FFF;
  border: 1px solid #cfd7e0;
}

QListView::item {
  border-radius: 2px;
  border: 1px solid transparent;
  color: #16212c;
  selection-color: #16212c;
  padding: 2px 4px;
}

QListView::item:hover {
  background-color: #edf3f7;
  border: 1px solid #edf3f7;
}

QListView::item:selected {
  background-color: #f3f6f8;
  border: 1px solid #d7dde3;
}

QListView::item:selected:active {
  background-color: #dcecf6;
  border: 1px solid #9fbed3;
}

QTreeView {
  background-color: #FFF;
  color: #16212c;
  selection-background-color: #FFF;
  selection-color: #16212c;
  border: 1px solid #cfd7e0;
}

QTreeView::item {
  min-width: 60px;
  border: 1px solid transparent;
  border-left: 0;
  border-right: 0;
  color: #16212c;
  padding: 2px 4px;
  selection-color: #16212c;
  border-radius: 0;
}

QTreeView::item:first,
QTreeView::item:only-one {
  border-left: 1px solid transparent;
  border-top-left-radius: 2px;
  border-bottom-left-radius: 2px;
}

QTreeView::item:last,
QTreeView::item:only-one {
  border-right: 1px solid transparent;
  border-top-right-radius: 2px;
  border-bottom-right-radius: 2px;
}

QTreeView::item:hover,
QTreeView::item:focus {
  background-color: #edf3f7;
  border-color: #edf3f7;
}

QTreeView::item:selected {
  background-color: #f3f6f8;
  border: 1px solid #d7dde3;
  border-right: 0;
  border-left: 0;
}

QTreeView::item:selected:first,
QTreeView::item:selected:only-one {
  border-left: 1px solid #d7dde3;
}

QTreeView::item:selected:last,
QTreeView::item:selected:only-one {
  border-right: 1px solid #d7dde3;
}

QTreeView::item:selected:active {
  background-color: #dcecf6;
  border: 1px solid #9fbed3;
  border-right: 0;
  border-left: 0;
}

QTreeView::item:selected:active:first,
QTreeView::item:selected:active:only-one {
  border-left: 1px solid #9fbed3;
}

QTreeView::item:selected:active:last,
QTreeView::item:selected:active:only-one {
  border-right: 1px solid #9fbed3;
}

QTreeView::branch {
  background-color: #FFF;
  border-image: none;
  image: none;
  padding-left: 3px;
  padding-top: 1px;
}

QTreeView::branch:has-children:closed {
  image: url(skin:controls/branch_closed.svg);
}

QTreeView::branch:has-children:open {
  image: url(skin:controls/branch_open.svg);
}

QHeaderView {
  border-bottom: 1px solid #cfd7e0;
  border-radius: 0;
}

QHeaderView::section {
  border: 0;
  background-color: #f8fafc;
  color: #16212c;
  padding: 4px;
  padding-left: 8px;
  padding-right: 20px;
  border-radius: 0;
}

QHeaderView::down-arrow,
QHeaderView::up-arrow {
  margin: 1px;
  top: 1px;
  right: 5px;
  width: 14px;
}

QHeaderView::down-arrow {
  image: url(skin:controls/arrow_down.svg);
}

QHeaderView::up-arrow {
  image: url(skin:controls/arrow_up.svg);
}

QTabWidget::pane {
  background-color: #f8fafc;
  border: 1px solid #cfd7e0;
}

QTabWidget::pane:top {
  margin-top: -1px;
  border-radius: 2px;
  border-top-left-radius: 0;
}

QTabWidget::pane:bottom {
  margin-bottom: -1px;
  border-radius: 2px;
  border-bottom-left-radius: 0;
}

QTabWidget::tab-bar {
  background-color: #edf1f5;
}

QTabBar::tab {
  color: #16212c;
  background-color: #e9eef2;
  padding: 6px 16px;
  border-radius: 0;
  border: 1px solid #cfd7e0;
  border-right: 0;
}

QTabBar::tab:last,
QTabBar::tab:only-one {
  border-right: 1px solid #cfd7e0;
}

QTabBar::tab:hover {
  background-color: #dde5ec;
}

QTabBar::tab:disabled {
  color: #95a1ad;
}

QTabBar::tab:selected {
  color: #16212c;
  background-color: #f8fafc;
}

QTabBar::tab:top {
  border-bottom: 0;
  margin-bottom: 1px;
}

QTabBar::tab:bottom {
  border-top: 0;
  margin-top: 1px;
}

QTabBar::tab:top:selected {
  padding-bottom: 7px;
  margin-bottom: 0;
}

QTabBar::tab:bottom:selected {
  padding-top: 7px;
  margin-top: 0;
}

QTabBar::tab:top:first,
QTabBar::tab:top:only-one {
  border-top-left-radius: 2px;
}

QTabBar::tab:top:last,
QTabBar::tab:top:only-one {
  border-top-right-radius: 2px;
}

QTabBar::tab:bottom:first,
QTabBar::tab:bottom:only-one {
  border-bottom-left-radius: 2px;
}

QTabBar::tab:bottom:last,
QTabBar::tab:bottom:only-one {
  border-bottom-right-radius: 2px;
}

QScrollBar {
  border-radius: 0;
  font-size: 13pt;
}

QScrollBar:vertical {
  border-left: 1px solid #d2dbe4;
  width: 1em;
}

QScrollBar:horizontal {
  border-top: 1px solid #d2dbe4;
  height: 1em;
}

QScrollBar::handle {
  margin: -1px;
  background: #c7d4df;
  border: 1px solid #cfd7e0;
}

QScrollBar::handle:vertical {
  min-height: 10px;
}

QScrollBar::handle:horizontal {
  min-width: 10px;
}

QScrollBar::handle:hover {
  background: #b8c7d4;
}

QScrollBar::left-arrow,
QScrollBar::right-arrow,
QScrollBar::up-arrow,
QScrollBar::down-arrow,
QScrollBar::sub-line,
QScrollBar::add-line,
QScrollBar::add-page,
QScrollBar::sub-page {
  background: #edf1f5;
  height: 0;
  width: 0;
  border-radius: 0;
  border: 0;
}

QAbstractScrollArea::corner {
  border-left: 1px solid #d2dbe4;
  border-top: 1px solid #d2dbe4;
  height: 0;
  width: 0;
  border-radius: 0;
  border-top: 1px solid #d2dbe4;
  border-left: 1px solid #d2dbe4;
  background: #FFF;
}

QLineEdit,
QComboBox,
QSpinBox,
QAbstractSpinBox {
  color: #16212c;
  padding: 4px;
  min-height: 1em;
}

QComboBox,
QSpinBox,
QAbstractSpinBox {
  border: 1px solid #c7d2dd;
  background-color: #FFF;
}

QLineEdit,
QTextEdit,
QPlainTextEdit,
QSpinBox,
QAbstractSpinBox,
QComboBox:editable {
  border: 1px solid #c7d2dd;
  background-color: #FFF;
}

QSpinBox,
QAbstractSpinBox {
  min-width: 2.5em;
  padding-right: 10px;
}

QPushButton:disabled,
QLineEdit:disabled,
QTextEdit:disabled,
QPlainTextEdit:disabled,
QListWidget:disabled,
QTreeWidget:disabled,
QComboBox:disabled,
QSpinBox:disabled,
QAbstractSpinBox:disabled {
  border: 1px solid transparent;
  background-color: #eef2f5;
}

QComboBox::drop-down,
QAbstractSpinBox::drop-down,
QSpinBox::drop-down,
QDateTimeEdit::drop-down {
  background-color: #FFF;
  border: 0;
  margin-left: 4px;
  margin-right: 12px;
  margin-top: 5px;
}

QComboBox::down-arrow,
QDateTimeEdit::down-arrow {
  margin-top: -2px;
  image: url(skin:controls/arrow_down.svg);
  width: 14px;
}

QComboBox::down-arrow:disabled,
QDateTimeEdit::down-arrow:disabled {
  image: url(skin:controls/arrow_down_disabled.svg);
}

QToolButton[popupMode="1"],
QToolButton[popupMode="2"],
QPushButton[popupMode="1"],
QPushButton[popupMode="2"] {
  padding-right: 14px;
}

QToolButton::menu-arrow,
QToolButton::menu-indicator,
QPushButton::menu-arrow,
QPushButton::menu-indicator {
  image: url(skin:controls/arrow_down.svg);
  subcontrol-origin: padding;
  subcontrol-position: center right;
  top: 2px;
  right: 2px;
  width: 14px;
}

QSpinBox::down-button,
QAbstractSpinBox::down-button {
  padding-right: 4px;
  image: url(skin:controls/arrow_down.svg);
  width: 14px;
  padding-bottom: 1px;
}

QSpinBox::down-button:disabled,
QAbstractSpinBox::down-button:disabled {
  image: url(skin:controls/arrow_down_disabled.svg);
}

QSpinBox::up-button,
QAbstractSpinBox::up-button {
  padding-right: 4px;
  image: url(skin:controls/arrow_up.svg);
  width: 14px;
  padding-top: 1px;
}

QSpinBox::up-button:disabled,
QAbstractSpinBox::up-button:disabled {
  image: url(skin:controls/arrow_up_disabled.svg);
}

QComboBox QAbstractItemView {
  background-color: #FFF;
  border: 1px solid #cfd7e0;
  color: #16212c;
  border-radius: 0;
}

QLabel,
QCheckBox,
QAbstractCheckBox,
QTreeView::indicator,
QRadioButton {
  color: #16212c;
  background: transparent;
}

QCheckBox::indicator,
QTreeView::indicator {
  background-color: #FFF;
  border: 1px solid #c7d2dd;
  height: 13px;
  width: 13px;
  margin-top: 1px;
}

QMenu::indicator {
  padding-top: 2px;
  width: 12px;
  height: 12px;
  left: 6px;
  margin-right: 8px;
}

QCheckBox::indicator:checked,
QMenu::indicator:checked,
QTreeView::indicator:checked {
  image: url(skin:controls/checkbox_check_lite.svg);
}

QCheckBox::indicator:disabled,
QTreeView::indicator:disabled {
  border: 1px solid #f8fafc;
  background-color: #eef2f5;
}

QCheckBox::indicator:checked:disabled,
QTreeView::indicator:checked:disabled {
  border: 1px solid transparent;
  image: url(skin:controls/checkbox_check_disabled.svg);
}

QRadioButton::indicator {
  background: #FFF;
  border: 1px solid #c7d2dd;
  border-radius: 7px;
  height: 12px;
  width: 12px;
}

QTreeView::indicator {
  background: #FFF;
}

QRadioButton::indicator:disabled {
  background-color: #eef2f5;
  margin: 1px;
  border: 1px solid transparent;
}

QRadioButton::indicator:checked {
  image: url(skin:controls/radio_check_lite.svg);
}

QRadioButton::indicator:checked:disabled {
  image: url(skin:controls/radio_check_disabled.svg);
}

QSlider::groove {
  background: #f6f9fb;
  border: 1px solid #d8e0e7;
  border-radius: 2px;
  font-size: 6pt;
}

QSlider::groove:horizontal {
  height: 0.8em;
}

QSlider::groove:vertical {
  width: 0.8em;
}

QSlider::groove:disabled,
QSlider::sub-page:disabled {
  background: #eef2f5;
  border: 1px solid transparent;
  border-radius: 2px;
}

QSlider::sub-page {
  background: #6aa4cf;
  border: 1px solid #629bc5;
  border-radius: 2px;
}

QSlider::handle {
  background: #FFF;
  border: 1px solid #a8b6c2;
  border-radius: 3px;
  font-size: 5pt;
}

QSlider::handle:horizontal {
  margin: -5px -1px;
  width: 4.5em;
}

QSlider::handle:vertical {
  margin: -1px -5px;
  height: 4.5em;
}

QSlider::handle:focus {
  background-color: #e3eff8;
  border-color: #79abc9;
}

QSlider::handle:hover {
  background-color: #f3f6f9;
}

QSlider::handle:pressed {
  background-color: #dcecf6;
  border-color: #79abc9;
}

QSlider::handle:disabled {
  background-color: #eef2f5;
  border: 1px solid #eef2f5;
}

QCheckBox::indicator:focus,
QTreeView::indicator:focus,
QRadioButton::indicator:focus,
QComboBox:focus {
  background-color: #eef6fb;
}

QCheckBox::indicator:focus:hover,
QTreeView::indicator:focus:hover,
QRadioButton::indicator:focus:hover,
QComboBox:focus:hover {
  background-color: #dcecf6;
  border-color: #79abc9;
}

QCheckBox::indicator:hover,
QTreeView::indicator:hover,
QRadioButton::indicator:hover,
QComboBox:hover {
  background-color: #f5f8fb;
  border-color: #b0beca;
}

QLineEdit:focus,
QSpinBox:focus,
QAbstractSpinBox:focus,
QComboBox:editable:focus {
  background-color: #FFF;
}

QLineEdit:focus:hover,
QSpinBox:focus:hover,
QAbstractSpinBox:focus:hover,
QComboBox:editable:focus:hover {
  border-color: #79abc9;
}

QLineEdit:hover,
QSpinBox:hover,
QAbstractSpinBox:hover,
QComboBox:editable:hover {
  background-color: #FFF;
  border-color: #b0beca;
}

QCheckBox::indicator:focus,
QTreeView::indicator:focus,
QRadioButton::indicator:focus,
QComboBox:focus,
QLineEdit:focus,
QTextEdit:focus,
QPlainTextEdit:focus,
QSpinBox:focus,
QAbstractSpinBox:focus,
QComboBox:editable:focus {
  border-color: #6ea8d3;
}

QFontDialog {
  min-width: 32em;
  min-height: 24em;
}

QColorDialog QColorLuminancePicker {
  background-color: transparent;
}

QMessageBox,
QDialogButtonBox {
  dialogbuttonbox-buttons-have-icons: 0;
}

/* Mumble Specifics */
LogTextBrowser,
#qdsChat {
  margin: 0 2px;
  min-height: 120px;
  min-width: 40px;
  border-color: #cfd7e0;
}

UserView {
  margin: 0 2px;
  min-height: 120px;
  min-width: 40px;
}

UserView::item {
  padding: 0;
  padding-top: -1px;
}

#qdwChat {
  background-color: #edf1f5;
  border: 1px solid #cfd7e0;
}

#qcbPersistentChatScope,
#qtePersistentChatWelcome,
#qtePersistentChatHistory,
#qteChat,
#qleAdvertisedRelease,
#qleAdvertisedOS,
#qleAdvertisedOSVersion {
  background-color: #FFF;
  color: #16212c;
  border: 1px solid #cfd7e0;
  selection-background-color: #4d8fbe;
  selection-color: #FFF;
}

#qcbPersistentChatScope {
  padding: 4px;
}

#qtePersistentChatWelcome,
#qtePersistentChatHistory,
#qteChat,
#qdwChat > QTextEdit {
  padding: 0;
  margin: 0 1px 1px 1px;
  font-size: 13pt;
}

#qfPersistentChatDivider {
  background-color: #d4dde7;
  color: #d4dde7;
  border: 0;
  min-height: 1px;
  max-height: 1px;
}

#qgbPrivacy,
#qgbAnnouncedIdentity {
  margin-top: 8px;
}

#qcbLinkPreviews {
  color: #16212c;
}

#qtIconToolbar QComboBox {
  font-size: 11pt;
}

.persistent-chat-preview-card {
  background-color: #FFF;
  border: 1px solid #cfd7e0;
}

.persistent-chat-preview-subtitle,
.persistent-chat-preview-status {
  color: #95a1ad;
}

.persistent-chat-preview-status {
  font-style: italic;
}

.log-time {
  background-color: transparent;
  color: #8a97a5;
  font-size: 12pt;
}

.log-server {
  background-color: transparent;
  color: #d97a73;
  font-weight: bold;
}

.log-channel {
  background-color: transparent;
  color: #c7925b;
  font-weight: bold;
}

.log-privilege {
  background-color: transparent;
  color: #c46a74;
  font-weight: bold;
}

.log-target {
  background-color: transparent;
  color: #69b28c;
  font-weight: bold;
}

.log-source {
  background-color: transparent;
  color: #69b28c;
  font-weight: bold;
}

QListView#qlwIcons {
  padding: 0;
  background-color: transparent;
  border: 0;
  font-size: 15pt;
  min-width: 165%;
  margin-left: 4px;
  margin-top: 12px;
}

QListView#qlwIcons::item {
  margin-bottom: 1px;
  padding: 5px 7px;
}

QListView#qlwIcons::item:hover {
  border-color: #dbe4ec;
  background-color: #dbe4ec;
}

QListView#qlwIcons::item:selected {
  background-color: #FFF;
  border: 1px solid #c4d0dc;
}

QListView#qlwIcons::item:focus {
  background-color: #dcecf6;
  border: 1px solid #9fbed3;
}

QSlider {
  margin-left: 30px;
  margin-right: 30px;
}

#qswPages > * > * > QScrollBar {
  margin: 0;
}

#qswPages > * > QWidget {
  margin: 2px;
}

QListView::item QListWidgetItem,
QListView::item QLineEdit,
QTreeView::item QComboBox,
QTreeView::item QLineEdit {
  background: #FFF;
  margin: 0;
  padding-top: 0;
  padding-bottom: 0;
  padding-left: 4px;
  padding-right: 4px;
  font-size: 12pt;
}

QListView::item QListWidgetItem:hover,
QListView::item QLineEdit:hover,
QTreeView::item QComboBox:hover,
QTreeView::item QLineEdit:hover {
  background: #FFF;
}

AboutDialog > QTextBrowser,
AboutDialog QTextEdit {
  border: 0;
}

#qtbToolBar {
  border: 1px solid transparent;
  background: transparent;
}

#BanEditor {
  min-width: 600px;
}

#GlobalShortcutTarget {
  min-height: 600px;
}

ViewCert {
  min-height: 600px;
}

TalkingUI {
  background-color: #FFF;
}

TalkingUI > * {
  background-color: #FFF;
}

TalkingUI [selected=false] {
  background-color: #FFF;
}

TalkingUI [selected=false]:hover {
  background-color: #edf3f7;
}

TalkingUI [selected=true] {
  background-color: #dcecf6;
  border: 1px solid #9fbed3;
}

TalkingUI > QFrame {
  border: 1px solid;
  border-color: #cfd7e0;
  border-radius: 2px;
}

QToolBar {
  background-color: transparent;
  border: 0px;
  spacing: 0;
}

QToolButton:hover {
  background-color: transparent;
}

QToolButton:pressed {
  background-color: transparent;
}

QToolButton:on {
  background-color: transparent;
}

QToolButton:on:pressed {
  background-color: transparent;
}
